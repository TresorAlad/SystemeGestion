<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:controller="com.reservation.salles.ui.controller.ReservationsListController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" padding="16,16,16,16" styleClass="top-bar">
            <children>
                <Label text="Historique des réservations" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Retour" onAction="#handleRetour" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="24" padding="24,24,24,24">
            <children>

                <!-- nav comme sur le dashboard -->
                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="nav-bar">
                    <children>
                        <Button text="Tableau de bord"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleGoDashboard"/>
                        <Button text="Historique des réservations"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-dashboard"/>
                        <Button text="Mes salles"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleMesSalles"/>
                        <Button text="Ajouter Salle"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleGoToAddSalle"/>
                    </children>
                </HBox>

                <VBox spacing="12" styleClass="card">
                    <children>
                        <TableView fx:id="reservationsTable" prefHeight="360">
                            <columns>
                                <TableColumn fx:id="colSalle" text="Salle" prefWidth="220"/>
                                <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                                <TableColumn fx:id="colHeure" text="Horaire" prefWidth="180"/>
                                <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
                            </columns>
                        </TableView>

                        <Button text="Annuler la réservation sélectionnée"
                                onAction="#handleAnnuler"
                                styleClass="danger-button"
                                maxWidth="280"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>

