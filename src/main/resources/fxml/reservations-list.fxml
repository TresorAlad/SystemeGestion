<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:controller="com.reservation.salles.ui.controller.ReservationsListController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" styleClass="top-bar-user-label"/>
                <Button text="Profil" onAction="#handleProfile" styleClass="secondary-button"/>
                <Button text="Déconnexion" onAction="#handleLogout" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <children>

                <!-- nav comme sur le dashboard -->
                <HBox spacing="8" alignment="CENTER" styleClass="nav-bar">
                    <children>
                        <Button text="Tableau de bord"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleGoDashboard"/>
                        <Button text="Historique des réservations"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-dashboard"/>
                        <Button text="Mes salles"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleMesSalles"/>
                        <Button text="Ajouter Salle"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleGoToAddSalle"/>
                    </children>
                </HBox>

                <VBox spacing="12" styleClass="card" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="reservationsTable" prefHeight="360" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" text="Nom complet" prefWidth="180"/>
                                <TableColumn fx:id="colSalle" text="Salle" prefWidth="180"/>
                                <TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
                                <TableColumn fx:id="colHeure" text="Horaire" prefWidth="160"/>
                                <TableColumn fx:id="colStatut" text="Statut" prefWidth="110"/>
                                <TableColumn fx:id="colActions" text="Actions" prefWidth="240"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>

