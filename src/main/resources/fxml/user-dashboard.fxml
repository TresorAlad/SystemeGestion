<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:controller="com.reservation.salles.ui.controller.UserDashboardController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" styleClass="top-bar-user-label"/>
                <Button text="Profil" onAction="#handleProfile" styleClass="secondary-button"/>
                <Button text="Déconnexion" onAction="#handleLogout" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <children>

                <!-- barre d'onglets -->
                <HBox spacing="8" alignment="CENTER" styleClass="nav-bar">
                    <children>
                        <Button fx:id="btnDashboard"
                                text="Tableau de bord"
                                prefWidth="220"
                                prefHeight="70"
                                styleClass="btn-dashboard"
                                onAction="#goToDashboard"/>

                        <Button fx:id="btnHistorique"
                                text="Historique de réservation"
                                prefWidth="220"
                                prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#goToHistorique"/>
                    </children>
                </HBox>

                <VBox spacing="16" styleClass="card" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- En-tête avec titre + recherche -->
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="totalSallesLabel" text="Toutes les salles" styleClass="section-title"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <TextField fx:id="searchField"
                                           promptText="🔍 Rechercher une salle..."
                                           styleClass="search-field"
                                           prefWidth="280"/>
                            </children>
                        </HBox>

                        <!-- grille de cartes de salles -->
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                            <content>
                                <FlowPane fx:id="sallesFlow" hgap="24" vgap="24"
                                          prefWrapLength="880"
                                          styleClass="rooms-flow"/>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>
</BorderPane>

