<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:controller="com.reservation.salles.ui.controller.SalleFormController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" styleClass="top-bar-user-label"/>
                <Button text="Profil" onAction="#handleProfile" styleClass="secondary-button"/>
                <Button text="Déconnexion" onAction="#handleLogout" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <children>
                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="nav-bar">
                    <children>
                        <Button text="Tableau de bord"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleGoDashboard"/>
                        <Button text="Historique des réservations"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleMesReservations"/>
                        <Button text="Mes salles"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleMesSalles"/>
                        <Button text="Ajouter Salle"
                                prefWidth="260" prefHeight="80"
                                styleClass="btn-dashboard"/>
                    </children>
                </HBox>

                <VBox spacing="18" styleClass="card">
                    <children>
                        <Label text="Veuillez remplir les informations" styleClass="section-title"/>

                        <GridPane hgap="24" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <children>
                                <Label text="Nom de la salle/Réunion"
                                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="nomField" promptText="Nom"
                                           GridPane.rowIndex="1" GridPane.columnIndex="0"
                                           styleClass="text-input"/>

                                <Label text="Capacité de la salle"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                <TextField fx:id="capaciteField" promptText="Capacité"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <Label text="Type de salle"
                                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="typeField" promptText="Type"
                                           GridPane.rowIndex="3" GridPane.columnIndex="0"
                                           styleClass="text-input"/>

                                <Label text="Description"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                <TextArea fx:id="descriptionArea" promptText="Description"
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                            </children>
                        </GridPane>

                        <VBox spacing="8">
                            <children>
                                <Label text="Photo de la salle/Réunion"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="Choisir une image" onAction="#handleChoisirPhoto"
                                                styleClass="secondary-button"/>
                                        <Label fx:id="photoPathLabel" text="Aucune image sélectionnée"
                                               style="-fx-text-fill: #6b7280;"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <children>
                                <Button text="Suivant" onAction="#handleSuivant"
                                        styleClass="primary-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>

