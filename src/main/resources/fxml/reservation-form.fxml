<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Formulaire de demande de réservation d'une salle par l'utilisateur.
    Contient les champs pour la date, l'heure, les contacts et l'objet de la réunion.
-->
<BorderPane fx:controller="com.reservation.salles.ui.controller.ReservationFormController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <!-- Barre supérieure : Titre et Profil -->
    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <children>
                <Label text="Nouvelle réservation" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" styleClass="top-bar-user-label"/>
                <Button text="Profil" onAction="#handleProfile" styleClass="secondary-button"/>
                <Button text="Retour" onAction="#handleRetour" styleClass="secondary-button"/>
                <Button text="Déconnexion" onAction="#handleLogout" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <VBox spacing="16" alignment="TOP_CENTER">
            <padding>
                <Insets topRightBottomLeft="32"/>
            </padding>
            <children>
                <!-- Navigation dynamique selon le rôle (Utilisateur) -->
                <HBox fx:id="userNav" spacing="8" alignment="CENTER" styleClass="nav-bar" managed="false" visible="false">
                    <children>
                        <Button text="Tableau de bord" onAction="#handleGoDashboard"
                                prefWidth="220" prefHeight="70" styleClass="btn-outline"/>
                        <Button text="Historique de réservation" onAction="#handleGoHistorique"
                                prefWidth="220" prefHeight="70" styleClass="btn-outline"/>
                    </children>
                </HBox>

                <!-- Navigation dynamique selon le rôle (Gestionnaire) -->
                <HBox fx:id="managerNav" spacing="8" alignment="CENTER" styleClass="nav-bar" managed="false" visible="false">
                    <children>
                        <Button text="Tableau de bord" onAction="#handleGoDashboard"
                                prefWidth="220" prefHeight="70" styleClass="btn-outline"/>
                        <Button text="Historique de réservation" onAction="#handleGoHistorique"
                                prefWidth="220" prefHeight="70" styleClass="btn-outline"/>
                        <Button text="Mes salles" onAction="#handleGoMesSalles"
                                prefWidth="220" prefHeight="70" styleClass="btn-outline"/>
                        <Button text="Ajouter Salle" onAction="#handleGoAddSalle"
                                prefWidth="220" prefHeight="70" styleClass="btn-outline"/>
                    </children>
                </HBox>

                <!-- Carte contenant le formulaire de saisie de la réservation -->
                <VBox styleClass="card" spacing="16" prefWidth="640">
                    <children>
                        <GridPane hgap="18" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="30"/>
                                <ColumnConstraints percentWidth="70"/>
                            </columnConstraints>

                            <children>
                                <Label text="Salle :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <Label fx:id="salleLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Date :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <DatePicker fx:id="datePicker" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Heure début :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="heureDebutField" promptText="HH:MM"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <Label text="Heure fin :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <TextField fx:id="heureFinField" promptText="HH:MM"
                                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <Label text="Nom complet :" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <TextField fx:id="nomField" promptText="Ex: Jean Dupont"
                                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <Label text="Téléphone :" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                <TextField fx:id="telephoneField" promptText="Ex: +228 90 00 00 00"
                                           GridPane.rowIndex="5" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <Label text="Objet :" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                                <TextField fx:id="objetField" promptText="Ex: Réunion de projet"
                                           GridPane.rowIndex="6" GridPane.columnIndex="1"
                                           styleClass="text-input"/>
                            </children>
                        </GridPane>

                        <!-- Validation de la saisie -->
                        <Button text="Valider la demande"
                                onAction="#handleValider"
                                styleClass="primary-button"
                                maxWidth="220"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
