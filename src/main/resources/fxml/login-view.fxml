<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Vue de connexion (Login).
    Permet à l'utilisateur de s'authentifier par email et mot de passe.
-->
<StackPane fx:controller="com.reservation.salles.ui.controller.LoginController"
           xmlns:fx="http://javafx.com/fxml"
           minWidth="960" minHeight="540"
           styleClass="root-pane">
    <children>
        <!-- Conteneur central du formulaire de connexion -->
        <VBox spacing="18" alignment="CENTER" maxWidth="480" maxHeight="500" styleClass="card">
            <padding>
                <Insets topRightBottomLeft="24"/>
            </padding>
            <children>
                <Label text="Bienvenue!" styleClass="login-title"/>
                <Label text="Connectez-vous à votre compte"
                       styleClass="login-subtitle"/>

                <!-- Champs de saisie -->
                <Label text="Email"/>
                <TextField fx:id="emailField" promptText="exemple@gmail.com"
                           maxWidth="340" styleClass="text-input"/>

                <Label text="Password"/>
                <!-- Champ mot de passe avec option de visibilité -->
                <StackPane maxWidth="340">
                    <children>
                        <PasswordField fx:id="passwordField" promptText="******"
                                       styleClass="text-input" maxWidth="Infinity"/>
                        <TextField fx:id="passwordVisibleField" promptText="******"
                                   styleClass="text-input" maxWidth="Infinity"
                                   visible="false" managed="false"/>
                        <Button onAction="#togglePassword" text="👁"
                                styleClass="eye-button" StackPane.alignment="CENTER_RIGHT"/>
                    </children>
                </StackPane>

                <!-- Label d'affichage des erreurs d'authentification -->
                <Label fx:id="errorLabel" textFill="red"/>

                <!-- Bouton de connexion -->
                <Button text="Login" onAction="#handleLogin"
                        styleClass="primary-button" maxWidth="340"/>

                <!-- Lien vers la création de compte -->
                <HBox alignment="CENTER" spacing="8">
                    <children>
                        <Label text="Pas de compte ?"/>
                        <Button text="Créer un compte"
                                onAction="#handleGoToRegister"
                                styleClass="secondary-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>

