<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:controller="com.reservation.salles.ui.controller.NotificationController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" padding="16,16,16,16" styleClass="top-bar">
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane>
            <children>
                <VBox alignment="CENTER" spacing="12" styleClass="notification-card">
                    <children>
                        <Label fx:id="iconLabel" text="✓" style="-fx-font-size: 48px;"/>
                        <Label fx:id="messageLabel" text="Réservation Réussie"
                               style="-fx-font-size: 16px; -fx-font-weight: 600;"/>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>

