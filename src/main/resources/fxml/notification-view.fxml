<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Vue de Notification (Succès / Erreur).
    Affiche un message de confirmation ou d'erreur avec une icône et un bouton d'action.
-->
<BorderPane fx:controller="com.reservation.salles.ui.controller.NotificationController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
            </children>
        </HBox>
    </top>

    <!-- Conteneur centré pour le message de notification -->
    <center>
        <VBox alignment="CENTER" spacing="30" maxWidth="500">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <children>
                <!-- Carte de notification -->
                <VBox alignment="CENTER" spacing="20" styleClass="card">
                    <children>
                        <!-- Icône de la notification (Succès/Erreur) -->
                        <StackPane>
                            <children>
                                <Label fx:id="iconLabel" text="✓" styleClass="notification-icon-large"/>
                            </children>
                        </StackPane>
                        
                        <!-- Textes de la notification -->
                        <VBox alignment="CENTER" spacing="8">
                            <children>
                                <Label fx:id="messageLabel" text="Opération Réussie" styleClass="notification-title"/>
                                <Label fx:id="descriptionLabel" text="Votre demande a été traitée avec succès." 
                                       styleClass="notification-description" wrapText="true" textAlignment="CENTER"/>
                            </children>
                        </VBox>
                        
                        <!-- Bouton d'action pour la redirection -->
                        <Button fx:id="actionButton" onAction="#handleAction" 
                                styleClass="primary-button" prefWidth="200"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>

