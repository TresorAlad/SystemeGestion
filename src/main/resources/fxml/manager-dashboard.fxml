<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:controller="com.reservation.salles.ui.controller.ManagerDashboardController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets topRightBottomLeft="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" styleClass="top-bar-user-label"/>
                <Button text="Déconnexion" onAction="#handleLogout" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets topRightBottomLeft="24"/>
            </padding>
            <children>

                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="nav-bar">
                    <children>
                        <Button text="Tableau de bord"
                                prefWidth="260"
                                prefHeight="80"
                                styleClass="btn-dashboard"/>

                        <Button text="Historique des réservations"
                                prefWidth="260"
                                prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleMesReservations"/>

                        <Button text="Mes salles"
                                prefWidth="260"
                                prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleMesSalles"/>

                        <Button text="Ajouter Salle"
                                prefWidth="260"
                                prefHeight="80"
                                styleClass="btn-outline"
                                onAction="#handleGoToAddSalle"/>
                    </children>
                </HBox>

                <!-- Cartes statistiques -->
                <HBox spacing="16">
                    <children>
                        <VBox spacing="8" styleClass="card">
                            <children>
                                <Label text="Réservations actives" styleClass="section-title"/>
                                <Label fx:id="reservationsActivesLabel"
                                       style="-fx-font-size: 24px; -fx-font-weight: 700;"/>
                            </children>
                        </VBox>

                        <VBox spacing="8" styleClass="card">
                            <children>
                                <Label text="Salles disponibles" styleClass="section-title"/>
                                <Label fx:id="sallesDisponiblesLabel"
                                       style="-fx-font-size: 24px; -fx-font-weight: 700;"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Tableau des réservations récentes -->
                <VBox spacing="12" styleClass="card">
                    <children>
                        <Label text="Réservations récentes" styleClass="section-title"/>
                        <TableView fx:id="recentesTable" prefHeight="260">
                            <columns>
                                <TableColumn fx:id="colSalle" text="SALLE" prefWidth="220"/>
                                <TableColumn fx:id="colDate" text="DATE" prefWidth="120"/>
                                <TableColumn fx:id="colHeure" text="HORAIRE" prefWidth="180"/>
                                <TableColumn fx:id="colStatut" text="STATUT" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>
</BorderPane>

