<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    Tableau de bord du Gestionnaire.
    Présente des statistiques globales et la liste des réservations récentes pour validation.
-->
<BorderPane fx:controller="com.reservation.salles.ui.controller.ManagerDashboardController"
            xmlns:fx="http://javafx.com/fxml"
            minWidth="960" minHeight="540"
            styleClass="root-pane">

    <!-- Barre supérieure : Titre et Profil -->
    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" styleClass="top-bar-user-label"/>
                <Button text="Profil" onAction="#handleProfile" styleClass="secondary-button"/>
                <Button text="Déconnexion" onAction="#handleLogout" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <!-- Contenu central -->
    <center>
        <VBox spacing="24" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <children>

                <!-- Menu de navigation principal du gestionnaire -->
                <HBox spacing="8" alignment="CENTER" styleClass="nav-bar">
                    <children>
                        <Button text="Tableau de bord"
                                prefWidth="220"
                                prefHeight="70"
                                styleClass="btn-dashboard"/>

                        <Button text="Historique des réservations"
                                prefWidth="220"
                                prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleMesReservations"/>

                        <Button text="Mes salles"
                                prefWidth="220"
                                prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleMesSalles"/>

                        <Button text="Ajouter Salle"
                                prefWidth="220"
                                prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleGoToAddSalle"/>
                    </children>
                </HBox>

                <!-- Section des statistiques rapides (Compteurs) -->
                <HBox spacing="16">
                    <children>
                        <VBox spacing="8" styleClass="card">
                            <children>
                                <Label text="Réservations actives" styleClass="section-title"/>
                                <Label fx:id="reservationsActivesLabel"
                                       style="-fx-font-size: 24px; -fx-font-weight: 700;"/>
                            </children>
                        </VBox>

                        <VBox spacing="8" styleClass="card">
                            <children>
                                <Label text="Salles disponibles" styleClass="section-title"/>
                                <Label fx:id="sallesDisponiblesLabel"
                                       style="-fx-font-size: 24px; -fx-font-weight: 700;"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Liste des dernières réservations soumises -->
                <VBox spacing="12" styleClass="card" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="Réservations récentes" styleClass="section-title"/>
                        <TableView fx:id="recentesTable" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colSalle" text="SALLE" prefWidth="220"/>
                                <TableColumn fx:id="colDate" text="DATE" prefWidth="120"/>
                                <TableColumn fx:id="colHeure" text="HORAIRE" prefWidth="180"/>
                                <TableColumn fx:id="colStatut" text="STATUT" prefWidth="120"/>
                                <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="200"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>
</BorderPane>

