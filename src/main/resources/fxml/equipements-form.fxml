<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Formulaire de gestion des équipements d'une salle.
    Permet d'associer jusqu'à 4 types d'équipements (ex: Vidéoprojecteur, Chaises) avec leurs quantités respectives.
-->
<BorderPane fx:controller="com.reservation.salles.ui.controller.EquipementsFormController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <!-- Barre supérieure : Titre et Profil -->
    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentUserLabel" styleClass="top-bar-user-label"/>
                <Button text="Profil" onAction="#handleProfile" styleClass="secondary-button"/>
                <Button text="Déconnexion" onAction="#handleLogout" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <children>
                <!-- Barre de navigation rapide -->
                <HBox spacing="8" alignment="CENTER" styleClass="nav-bar">
                    <children>
                        <Button text="Tableau de bord"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleGoDashboard"/>
                        <Button text="Historique des réservations"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleMesReservations"/>
                        <Button text="Mes salles"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-outline"
                                onAction="#handleMesSalles"/>
                        <Button text="Ajouter Salle"
                                prefWidth="220" prefHeight="70"
                                styleClass="btn-dashboard"
                                onAction="#handleAjouterSalle"/>
                    </children>
                </HBox>

                <!-- Carte du formulaire d'équipements -->
                <VBox spacing="18" styleClass="card">
                    <children>
                        <Label text="Equipement" styleClass="section-title"/>

                        <!-- Grille de sélection des équipements -->
                        <GridPane hgap="40" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <children>
                                <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <Label text="Quantité" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <!-- Ligne d'équipement 1 -->
                                <ComboBox fx:id="nom1Field" promptText="Choisir un équipement"
                                          GridPane.rowIndex="1" GridPane.columnIndex="0"
                                          maxWidth="Infinity" styleClass="combo-box"/>
                                <TextField fx:id="qte1Field" promptText="Quantité"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <!-- Ligne d'équipement 2 -->
                                <ComboBox fx:id="nom2Field" promptText="Choisir un équipement"
                                          GridPane.rowIndex="2" GridPane.columnIndex="0"
                                          maxWidth="Infinity" styleClass="combo-box"/>
                                <TextField fx:id="qte2Field" promptText="Quantité"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <!-- Ligne d'équipement 3 -->
                                <ComboBox fx:id="nom3Field" promptText="Choisir un équipement"
                                          GridPane.rowIndex="3" GridPane.columnIndex="0"
                                          maxWidth="Infinity" styleClass="combo-box"/>
                                <TextField fx:id="qte3Field" promptText="Quantité"
                                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <!-- Ligne d'équipement 4 -->
                                <ComboBox fx:id="nom4Field" promptText="Choisir un équipement"
                                          GridPane.rowIndex="4" GridPane.columnIndex="0"
                                          maxWidth="Infinity" styleClass="combo-box"/>
                                <TextField fx:id="qte4Field" promptText="Quantité"
                                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                                           styleClass="text-input"/>
                            </children>
                        </GridPane>

                        <!-- Actions finales de validation -->
                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <children>
                                <Button text="Annuler" onAction="#handleAnnuler" styleClass="danger-button"/>
                                <Button text="Ajouter" onAction="#handleAjouter" styleClass="primary-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>

