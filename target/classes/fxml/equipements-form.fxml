<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:controller="com.reservation.salles.ui.controller.EquipementsFormController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540"
            styleClass="root-pane">

    <top>
        <HBox spacing="16" styleClass="top-bar">
            <padding>
                <Insets topRightBottomLeft="16"/>
            </padding>
            <children>
                <Label text="Réservation de Salles" styleClass="title-label"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Annuler" onAction="#handleAnnuler" styleClass="secondary-button"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets topRightBottomLeft="24"/>
            </padding>
            <children>
                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="nav-bar">
                    <children>
                        <Button text="Equipement" styleClass="nav-pill nav-pill-active"/>
                    </children>
                </HBox>

                <VBox spacing="18" styleClass="card">
                    <children>
                        <Label text="Equipement" styleClass="section-title"/>

                        <GridPane hgap="40" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <children>
                                <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <Label text="Quantité" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <TextField fx:id="nom1Field" promptText="Nom"
                                           GridPane.rowIndex="1" GridPane.columnIndex="0"
                                           styleClass="text-input"/>
                                <TextField fx:id="qte1Field" promptText="Quantité"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <TextField fx:id="nom2Field" promptText="Nom"
                                           GridPane.rowIndex="2" GridPane.columnIndex="0"
                                           styleClass="text-input"/>
                                <TextField fx:id="qte2Field" promptText="Quantité"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <TextField fx:id="nom3Field" promptText="Nom"
                                           GridPane.rowIndex="3" GridPane.columnIndex="0"
                                           styleClass="text-input"/>
                                <TextField fx:id="qte3Field" promptText="Quantité"
                                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                                           styleClass="text-input"/>

                                <TextField fx:id="nom4Field" promptText="Nom"
                                           GridPane.rowIndex="4" GridPane.columnIndex="0"
                                           styleClass="text-input"/>
                                <TextField fx:id="qte4Field" promptText="Quantité"
                                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                                           styleClass="text-input"/>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <children>
                                <Button text="Annuler" onAction="#handleAnnuler" styleClass="danger-button"/>
                                <Button text="Ajouter" onAction="#handleAjouter" styleClass="primary-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>

